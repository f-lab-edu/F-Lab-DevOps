# ── 데이터베이스 연결 정보 ─────────────────────────────────────
# 형식: postgresql://유저:비밀번호@호스트:포트/DB이름

# 로컬 환경
# DATABASE_URL=postgresql://postgres:dpdlvldzm1%40@localhost:5432/tempdb

# docker-compose 환경에서 호스트는 서비스 이름(host.docker.internal)을 사용
DATABASE_URL=postgresql://postgres:dpdlvldzm1%40@host.docker.internal:5432/tempdb

# ── 애플리케이션 설정 ──────────────────────────────────────────
APP_ENV=development
DEBUG=True
