###############################################
# url-shortener 환경변수 예시 파일 (.env.example)
# 이 파일은 형식 안내용이며, 실제 비밀번호는 넣지 않습니다.
# 사용 방법:
#   cp .env.example .env
#   그리고 .env 파일을 열어 각자 환경에 맞게 수정하세요.
###############################################

# ── 공통 애플리케이션 설정 ──────────────────────────────────────
APP_ENV=development
DEBUG=True

# ── 데이터베이스 설정 ───────────────────────────────────────────

# docker-compose (API + PostgreSQL 함께 실행)용 DB 계정 정보
# docker-compose.yml 의 db 서비스에서 사용됩니다.
POSTGRES_USER={urluser}
POSTGRES_PASSWORD={change}
POSTGRES_DB={urldb}

# 애플리케이션에서 사용하는 DATABASE_URL
# 실행 방식에 따라 주석을 적절히 바꿔 사용하세요.

## A. uvicorn 직접 실행 시 (로컬 PostgreSQL 접속)
# DATABASE_URL=postgresql://postgres:비밀번호@localhost:5432/tempdb

## B. docker run 단독 실행 시
# 컨테이너에서 호스트 DB 로 접속해야 하므로 host.docker.internal 사용
# DATABASE_URL=postgresql://postgres:비밀번호@host.docker.internal:5432/tempdb

## C. docker-compose 실행 시 (위 POSTGRES_* 값을 사용)
DATABASE_URL=postgresql://urluser:change-me@db:5432/urldb

